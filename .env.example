# Copy values to root `.env` (see README).

# --- dotenv-vault (encrypted `.env.vault`; key must stay out of git) ---
DOTENV_KEY=

# --- Node ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL (docker-compose and apps) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
DATABASE_URL=

# --- pgAdmin (docker-compose pgadmin service) ---
# Use a valid email format for pgAdmin 9+ (avoid *.local)
PGADMIN_PORT=
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# --- Ollama (docker-compose profile: llm) ---
OLLAMA_PORT=11434
# --- Open WebUI (docker-compose profile: llm-ui) ---
OPEN_WEBUI_PORT=3001
COLD_UP_WITH_LLM_UI=0

# --- Telegram MTProto (GramJS) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Preferred in production: string session from vault (overrides file)
TELEGRAM_STRING_SESSION=
# Session file path relative to repo root (default `.telegram/session`)
TELEGRAM_SESSION_FILE=

# --- Worker: channel manifest and parser config (optional) ---
# Path to channel manifest JSON (relative or absolute), default `.radar/channels.manifest.json`
RADAR_CHANNEL_MANIFEST=
# JSON parse-config payload (batchLimit, markAsRead, cursor), default `.radar/parse.config.json`
RADAR_PARSE_CONFIG=
RADAR_PARSE_BATCH_LIMIT=
RADAR_PARSE_MARK_AS_READ=
RADAR_PARSER_VERSION=0.1.0
RADAR_PLACE_CACHE_TTL_DAYS=30
# Local path to geo artifacts for parser pipeline (optional)
RADAR_GEO_ARTIFACTS_DIR=

# --- Geocode enrichers (optional) ---
DADATA_TOKEN=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
RADAR_LLM_GEOCODER_ENABLED=0
RADAR_LLM_PROVIDER=ollama
RADAR_LLM_BASE_URL=http://127.0.0.1:11434/v1
RADAR_LLM_MODEL=qwen2.5:3b
RADAR_LLM_TIMEOUT_MS=5000
RADAR_LLM_MAX_TOKENS=220
RADAR_LLM_TEMPERATURE=0
RADAR_LLM_JSON_MODE=1
RADAR_LLM_RETRY_COUNT=1
DADATA_CACHE_TTL_DAYS=30
NOMINATIM_CACHE_TTL_DAYS=7
LLM_CACHE_TTL_DAYS=1
RADAR_GEO_MIN_CONFIDENCE=0.70
RADAR_GEO_VALIDATOR=rule

# --- Outbox relay / CQRS ---
RADAR_OUTBOX_RELAY_POLL_MS=1000
RADAR_OUTBOX_RELAY_BATCH_SIZE=100

# --- Place status tags / time-machine ---
RADAR_STATUS_INCLUDE_ON_MAP_DEFAULT=1
RADAR_STATUS_HISTORY_RETENTION_DAYS=365

# --- Worker demo flags ---
RADAR_BOOTSTRAP_DEMO_PARSE=0

# --- Admin bot ---
RADAR_ADMIN_BOT_ALLOWED_USER_IDS=


