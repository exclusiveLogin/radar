# Скопируйте в `.env` в корне репозитория или используйте dotenv-vault (см. README).

# --- dotenv-vault (секреты в шифрованном `.env.vault`; ключ только вне git) ---
DOTENV_KEY=

# --- Node ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL (docker-compose и приложения) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
DATABASE_URL=

# --- pgAdmin (docker-compose сервис pgadmin) ---
# Вход в pgAdmin (должен проходить валидацию email в pgAdmin 9+, не используйте *.local)
PGADMIN_PORT=
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# --- Telegram MTProto (GramJS) — только из vault / локального `.env` ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Предпочтительно в проде: строка сессии из vault (перекрывает файл)
TELEGRAM_STRING_SESSION=
# Путь к файлу сессии относительно корня репозитория (по умолчанию `.telegram/session`)
TELEGRAM_SESSION_FILE=

# --- Worker: манифест каналов и конфиг парсинга (опционально) ---
# Путь к JSON манифеста относительно корня или абсолютный; по умолчанию `.radar/channels.manifest.json`
RADAR_CHANNEL_MANIFEST=
# JSON с полями parse-config (batchLimit, markAsRead, cursor); по умолчанию `.radar/parse.config.json`
RADAR_PARSE_CONFIG=
RADAR_PARSE_BATCH_LIMIT=
RADAR_PARSE_MARK_AS_READ=
RADAR_PARSER_VERSION=0.1.0
RADAR_PLACE_CACHE_TTL_DAYS=30

# --- Geocode enrichers (опционально) ---
DADATA_TOKEN=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
RADAR_LLM_GEOCODER_ENABLED=0

# --- Outbox relay / CQRS ---
RADAR_OUTBOX_RELAY_POLL_MS=1000
RADAR_OUTBOX_RELAY_BATCH_SIZE=100

# --- Worker demo flags ---
RADAR_BOOTSTRAP_DEMO_PARSE=0

# --- Admin bot ---
RADAR_ADMIN_BOT_ALLOWED_USER_IDS=
